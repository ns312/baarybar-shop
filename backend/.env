# Server Configuration
PORT=3000

# Google Gemini API Key (Get a free one from Google AI Studio / Firebase Console)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# GreenAPI Credentials (Get them from your GreenAPI Console)
GREENAPI_ID=YOUR_GREENAPI_INSTANCE_ID_HERE
GREENAPI_TOKEN=YOUR_GREENAPI_INSTANCE_TOKEN_HERE

# Telegram Bot Credentials (Get them from @BotFather and @userinfobot in Telegram)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE
